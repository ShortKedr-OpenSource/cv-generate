{
    "name": "cv-generate",
    "version": "1.0.0",
    "private": true,
    "description": "CV web app with multilingual support, themes, and PDF export",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:local": "vite --host 127.0.0.1 --port 5173 --strictPort",
        "start": "npm run dev:local",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "preview:local": "vite preview --host 127.0.0.1 --port 4173 --strictPort"
    },
    "dependencies": {
        "vue": "^3.5.13"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2.1",
        "typescript": "^5.8.2",
        "vite": "^6.2.2",
        "vue-tsc": "^2.2.8"
    }
}
